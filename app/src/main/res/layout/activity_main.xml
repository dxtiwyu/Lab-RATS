<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="32dp">

                <ImageView
                    android:layout_width="230dp"
                    android:layout_height="136dp"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="16dp"
                    android:contentDescription="@string/content_desc_logo"
                    android:scaleType="centerInside"
                    android:src="@drawable/app_logo" />

                <TextView
                    android:id="@+id/tvAppTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:fontFamily="@font/orbitron"
                    android:letterSpacing="0.4"
                    android:shadowColor="@color/neon_cyan"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="20"
                    android:text="LAB-RATS"
                    android:textAllCaps="true"
                    android:textColor="@color/neon_cyan"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDevelopedBy"
                    android:layout_width="wrap_content"
                    android:layout_height="23dp"
                    android:layout_marginTop="4dp"
                    android:alpha="0.9"
                    android:fontFamily="@font/orbitron"
                    android:letterSpacing="0.2"
                    android:text="DEVELOPED BY K4N3CO.LABS"
                    android:textAllCaps="true"
                    android:textColor="@color/neon_cyan"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.3.2"
                    android:textSize="8sp"
                    android:textColor="@color/neon_cyan"
                    android:fontFamily="@font/orbitron"
                    android:alpha="0.6"
                    android:letterSpacing="0.3"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@color/neon_cyan"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="232dp"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginBottom="16dp"
                            android:fontFamily="@font/orbitron"
                            android:text="🔴 SERVER_OFFLINE"
                            android:textColor="@color/neon_red"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="16dp"
                            android:background="#1affffff" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.7"
                            android:letterSpacing="0.1"
                            android:text="VIRTUAL_UPLINK_INFO"
                            android:textAllCaps="true"
                            android:textColor="@color/neon_cyan"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tvIpAddress"
                            android:layout_width="match_parent"
                            android:layout_height="34dp"
                            android:layout_marginTop="8dp"
                            android:text="ADDR: [LOADING_DATA...]"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:alpha="0.7"
                            android:letterSpacing="0.1"
                            android:text="REMOTE_C2_LINK"
                            android:textAllCaps="true"
                            android:textColor="@color/neon_cyan"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tvServerUrl"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="8dp"
                            android:background="#0D00f2ff"
                            android:padding="12dp"
                            android:text="UPLINK_INACTIVE"
                            android:textColor="@color/neon_cyan"
                            android:textSize="12sp" />

                    </LinearLayout>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartStop"
                android:layout_width="match_parent"
                android:layout_height="49dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/neon_cyan"
                android:fontFamily="@font/orbitron"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="INITIALIZE SERVER"
                android:textColor="@color/bg_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopyUrl"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/orbitron"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="COPY LINK"
                android:textColor="@color/neon_cyan"
                android:textSize="12sp"
                app:cornerRadius="24dp"
                app:strokeColor="@color/neon_cyan"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBatteryOptimization"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/orbitron"
                android:text="BYPASS_POWER_LIMITS"
                android:textColor="@color/neon_cyan"
                android:textSize="12sp"
                app:cornerRadius="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[ SECURE CONNECTION ESTABLISHED ]"
                    android:textSize="10sp"
                    android:textColor="#333333"
                    android:fontFamily="@font/orbitron"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
